{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "anthropic": {
      "name": "{env:ANTHROPIC_PROVIDER_NAME}",
      "options": {
        "baseURL": "{env:ANTHROPIC_BASE_URL}",
        "apiKey": "{env:ANTHROPIC_AUTH_TOKEN}"
      },
      "models": {
        "google-claude-46-sonnet": { "name": "Sage Sonnet 4.6" },
        "google-claude-47-opus": { "name": "Sage Opus 4.7" }
      }
    }
  }
}
